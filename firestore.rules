rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function for app creator
    function isAppCreator() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.username == 'ezzah';
    }

    // Config: allow all to read, but only app creator to write
    match /config/{document=**} {
      allow read: if true;
      allow write: if true; // Just for testing, normally only app creator
    }

    // Users: any authenticated user can read, only owner can write
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Stealth Call Rooms (Legacy Rooms removed)
    match /rooms/{roomId} {
      allow create, read, update, delete: if request.auth != null;

      // Signaling subcollections per connection pair
      match /signaling/{connectionId} {
        allow read, write: if request.auth != null;

        match /candidates/{candidateId} {
          allow read, write: if request.auth != null;
        }
      }
    }

    // Presence: any authenticated can read, only owner can write
    match /presence/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Combos for Ghost Dial
    match /combos/{comboId} {
      allow read, write: if request.auth != null;
    }

    // Stealth Calls for Ghost Dial
    match /stealth_calls/{callId} {
      allow read, write: if request.auth != null;
    }
  }
}
